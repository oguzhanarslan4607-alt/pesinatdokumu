rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.email in [
            "admin@demo.com",
            "yonetici@sirket.com",
            "oguzhanarslan4607@gmail.com",
            "oguzhanarslangemini@gmail.com"
          ]
          || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == "admin"
        );
    }

    function isStaff() {
      return isAdmin()
        || (
          signedIn()
          && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == "staff"
        );
    }

    function validStatus(status) {
      return status in ["Teslim Edildi", "Teslim Edilmedi", "İptal"];
    }

    function validEntry(data) {
      return data.keys().hasAll([
          "receiptNo",
          "date",
          "staffName",
          "customerName",
          "amount",
          "status",
          "createdAt",
          "createdBy",
          "isDeleted"
        ])
        && data.keys().hasOnly([
          "receiptNo",
          "date",
          "staffName",
          "office",
          "customerName",
          "customerPhone",
          "amount",
          "image",
          "note",
          "status",
          "history",
          "createdAt",
          "createdBy",
          "isDeleted",
          "cancelReason",
          "cancelledAt",
          "cancelledBy"
        ])
        && data.receiptNo is string
        && data.date is string
        && data.staffName is string
        && data.customerName is string
        && data.amount is number
        && data.amount > 0
        && validStatus(data.status)
        && data.createdAt is string
        && data.createdBy is string
        && data.isDeleted is bool;
    }

    match /pesinatlar/{entryId} {
      allow read: if signedIn();
      allow create: if isStaff() && validEntry(request.resource.data);
      allow update: if isAdmin() && validEntry(request.resource.data);
      allow delete: if isAdmin();
    }

    match /_meta/{docId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /users/{email} {
      allow read: if signedIn();
      allow create, update: if isAdmin()
        && request.resource.data.email == email
        && request.resource.data.role in ["admin", "staff", "viewer"];
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.user == request.auth.token.email
        && request.resource.data.createdAt is string
        && request.resource.data.action is string;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
